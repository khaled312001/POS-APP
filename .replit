entrypoint = "README.md"
modules = ["nodejs-20", "web", "postgresql-16"]

[nix]
channel = "stable-25_05"
packages = ["chromium", "nss", "atk", "cups", "libdrm", "libxkbcommon", "xorg.libXext", "xorg.libX11", "xorg.libXcomposite", "xorg.libXcursor", "xorg.libXdamage", "xorg.libXfixes", "xorg.libXi", "xorg.libXrandr", "xorg.libXrender", "xorg.libXtst", "xorg.libxshmfence", "mesa", "expat", "glib", "nspr", "alsaLib", "pango", "cairo", "dbus", "fontconfig", "freetype", "udev"]

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm run expo:static:build && npm run server:build"]
run = ["npm", "run", "server:prod"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[env]
PORT = "5000"
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD = "true"
PUPPETEER_CACHE_DIR = "/home/runner/.cache/puppeteer"

[agent]
stack = "EXPO"
integrations = ["stripe:2.0.0"]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true && export DATABASE_URL=\"$NEON_DATABASE_URL\" && NODE_ENV=development npx tsx server/index.ts"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN:8080 REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost --port 8080"
waitForPort = 8080

[objectStorage]
defaultBucketID = "replit-objstore-ba0158fe-b737-4e3d-9065-def7c306785e"

[userenv]

[userenv.production]

[userenv.shared]
PORT = "5000"
