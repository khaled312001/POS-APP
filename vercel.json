{
  "version": 2,
  "redirects": [
    {
      "source": "/",
      "destination": "/app",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/app/_expo/:match*",
      "destination": "/_expo/:match*"
    },
    {
      "source": "/app/assets/:match*",
      "destination": "/assets/:match*"
    },
    {
      "source": "/app/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/app/sw.js",
      "destination": "/sw.js"
    },
    {
      "source": "/app/manifest.webmanifest",
      "destination": "/manifest.webmanifest"
    },
    {
      "source": "/app/:match*",
      "destination": "/index.html"
    },
    {
      "source": "/:match*",
      "destination": "/index.html"
    }
  ]
}
