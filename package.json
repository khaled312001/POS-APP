    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "~19.1.10",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vercel/node": "^5.6.22",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~10.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
