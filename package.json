{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package && node patches/fix-expo-cors.js && npx puppeteer browsers install chrome || true",
    "install-chrome": "npx puppeteer browsers install chrome",
    "expo:dev": "cross-env EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN:8080 cross-env REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN cross-env EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost --port 8080",
    "expo:local": "npx expo start",
    "expo:clean": "npx expo start -c",
    "server:dev": "cross-env NODE_ENV=development tsx --env-file=.env server/index.ts",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js && npx cross-env EXPO_PUBLIC_DOMAIN=pos.barmagly.tech npx expo export -p web && node scripts/post-export.js",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=cjs --outdir=server_dist",
    "server:prod": "cross-env NODE_ENV=production node --env-file-if-exists=.env server_dist/index.js",
    "db:push": "npx drizzle-kit push",
    "start": "npx expo start",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@google-cloud/storage": "^7.19.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@tanstack/react-query": "^5.83.0",
    "@types/nodemailer": "^7.0.11",
    "@ungap/structured-clone": "^1.3.0",
    "@wppconnect-team/wppconnect": "^1.41.0",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "esbuild": "^0.27.4",
    "expo": "~54.0.27",
    "expo-application": "~7.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-camera": "^17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.11",
    "expo-crypto": "~15.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.10",
    "expo-glass-effect": "~0.1.4",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.17",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.0.1",
    "google-auth-library": "^10.6.1",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.2",
    "pg": "^8.16.3",
    "puppeteer": "^24.38.0",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.4",
    "stripe": "^20.0.0",
    "stripe-replit-sync": "^1.0.0",
    "tsx": "^4.21.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
